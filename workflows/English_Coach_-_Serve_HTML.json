        "responseBody": "<!DOCTYPE html>\n<html lang=\"fr\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>EN.COACH</title>\n<link href=\"https://fonts.googleapis.com/css2?family=Syne:wght@400;700;800&family=Space+Mono:wght@400;700&display=swap\" rel=\"stylesheet\">\n<style>\n:root{--bg:#0d0d0f;--surface:#16161a;--surface2:#1e1e24;--border:#2a2a35;--accent:#f5c842;--accent2:#4af0a8;--accent3:#f06060;--text:#e8e8f0;--muted:#7070a0;--radius:10px}\n*{box-sizing:border-box;margin:0;padding:0}\nbody{background:var(--bg);color:var(--text);font-family:'Space Mono',monospace;min-height:100vh;display:flex;flex-direction:column;align-items:center;padding:24px 16px 60px}\n.wrap{width:100%;max-width:680px}\nheader{display:flex;align-items:center;justify-content:space-between;margin-bottom:24px}\n.logo{font-family:'Syne',sans-serif;font-weight:800;font-size:1.3rem}\n.logo span{color:var(--accent)}\n.stats{display:flex;gap:16px;font-size:0.73rem;color:var(--muted)}\n.stat-val{color:var(--accent2);font-weight:700}\n.progress-bar{height:3px;background:var(--border);border-radius:2px;margin-bottom:22px;overflow:hidden}\n.progress-fill{height:100%;background:linear-gradient(90deg,var(--accent),var(--accent2));transition:width 0.6s ease;width:0%}\n.topics{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:18px}\n.topic-btn{padding:6px 14px;background:var(--surface);border:1px solid var(--border);border-radius:20px;color:var(--muted);font-family:'Space Mono',monospace;font-size:0.71rem;cursor:pointer;transition:all 0.15s}\n.topic-btn:hover{border-color:var(--accent);color:var(--accent)}\n.topic-btn.active{background:var(--accent);border-color:var(--accent);color:#0d0d0f;font-weight:700}\n.level-row{display:flex;gap:8px;margin-bottom:18px;align-items:center}\n.level-label{font-size:0.69rem;color:var(--muted)}\n.level-btn{padding:4px 10px;background:var(--surface);border:1px solid var(--border);border-radius:12px;color:var(--muted);font-family:'Space Mono',monospace;font-size:0.68rem;cursor:pointer;transition:all 0.15s}\n.level-btn.active{background:var(--accent2);border-color:var(--accent2);color:#0d0d0f;font-weight:700}\n.voice-bar{display:flex;align-items:center;gap:10px;margin-bottom:18px;padding:10px 14px;background:var(--surface);border:1px solid var(--border);border-radius:8px}\n.voice-bar label{font-size:0.7rem;color:var(--muted)}\n.voice-btn{padding:5px 12px;border-radius:6px;font-family:'Space Mono',monospace;font-size:0.69rem;font-weight:700;cursor:pointer;border:none;transition:all 0.15s}\n.voice-btn.tts{background:rgba(245,200,66,0.15);color:var(--accent);border:1px solid rgba(245,200,66,0.3)}\n.voice-btn.tts.on{background:var(--accent);color:#0d0d0f}\n.voice-btn.stt{background:rgba(74,240,168,0.1);color:var(--accent2);border:1px solid rgba(74,240,168,0.25)}\n.voice-btn.stt.recording{background:var(--accent3);color:#fff;animation:recpulse 1s infinite}\n@keyframes recpulse{0%,100%{opacity:1}50%{opacity:0.6}}\n.session-badge{display:flex;align-items:center;gap:6px;font-size:0.69rem;color:var(--muted);margin-bottom:18px}\n.dot{width:6px;height:6px;border-radius:50%;background:var(--accent2);animation:pulse 2s infinite}\n@keyframes pulse{0%,100%{opacity:1}50%{opacity:0.3}}\n.card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:26px 26px 22px;margin-bottom:16px;position:relative;overflow:hidden}\n.card::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,var(--accent),transparent)}\n.exercise-meta{display:flex;align-items:center;gap:10px;margin-bottom:14px}\n.ex-type{font-size:0.61rem;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;padding:3px 8px;border-radius:4px;background:rgba(245,200,66,0.12);color:var(--accent);border:1px solid rgba(245,200,66,0.2)}\n.ex-level{font-size:0.64rem;color:var(--muted)}\n.question{font-family:'Syne',sans-serif;font-size:1.15rem;font-weight:700;line-height:1.4}\n.fr-hint{display:block;font-family:'Space Mono',monospace;font-size:0.75rem;font-weight:400;color:var(--muted);margin-top:6px}\n.options{display:flex;flex-direction:column;gap:8px;margin-top:16px}\n.opt{display:flex;align-items:center;gap:12px;padding:11px 15px;background:var(--surface2);border:1px solid var(--border);border-radius:8px;cursor:pointer;font-size:0.85rem;transition:all 0.15s}\n.opt:hover:not(.disabled){border-color:var(--accent);background:rgba(245,200,66,0.04)}\n.opt-letter{width:22px;height:22px;border-radius:4px;background:var(--border);display:flex;align-items:center;justify-content:center;font-size:0.69rem;font-weight:700;flex-shrink:0;color:var(--muted)}\n.opt.correct{border-color:var(--accent2);background:rgba(74,240,168,0.08)}\n.opt.correct .opt-letter{background:var(--accent2);color:#0d0d0f}\n.opt.wrong{border-color:var(--accent3);background:rgba(240,96,96,0.08)}\n.opt.wrong .opt-letter{background:var(--accent3);color:#fff}\n.opt.disabled{cursor:default}\n.fill-wrap{margin-top:16px;display:flex;gap:8px;flex-wrap:wrap;align-items:center}\n.sentence-part{font-size:0.93rem;line-height:2.4}\n.fill-input{background:var(--surface2);border:2px solid var(--border);border-radius:6px;color:var(--text);font-family:'Space Mono',monospace;font-size:0.88rem;padding:6px 12px;min-width:100px;outline:none;transition:border-color 0.15s}\n.fill-input:focus{border-color:var(--accent)}\n.fill-input.correct{border-color:var(--accent2);background:rgba(74,240,168,0.08)}\n.fill-input.wrong{border-color:var(--accent3);background:rgba(240,96,96,0.08)}\n.transl-input{width:100%;margin-top:14px;background:var(--surface2);border:2px solid var(--border);border-radius:8px;color:var(--text);font-family:'Space Mono',monospace;font-size:0.87rem;padding:12px 14px;outline:none;transition:border-color 0.15s;resize:none}\n.transl-input:focus{border-color:var(--accent)}\n.transl-input.correct{border-color:var(--accent2);background:rgba(74,240,168,0.08)}\n.transl-input.wrong{border-color:var(--accent3);background:rgba(240,96,96,0.08)}\n.fr-source{margin-top:14px;padding:14px 16px;background:var(--surface2);border-radius:8px;border-left:3px solid var(--accent);font-size:1rem;font-family:'Syne',sans-serif;font-weight:700}\n.feedback{margin-top:14px;padding:12px 16px;border-radius:8px;font-size:0.8rem;line-height:1.65;display:none;border-left:3px solid}\n.feedback.show{display:block;animation:slideIn 0.2s ease}\n.feedback.correct-fb{border-color:var(--accent2);background:rgba(74,240,168,0.06);color:#90f0c8}\n.feedback.wrong-fb{border-color:var(--accent3);background:rgba(240,96,96,0.06);color:#f09090}\n@keyframes slideIn{from{opacity:0;transform:translateY(4px)}to{opacity:1;transform:translateY(0)}}\n.hint-box{color:var(--muted);font-size:0.73rem;margin-top:10px}\n.btn-row{display:flex;gap:10px;margin-top:14px;flex-wrap:wrap}\n.btn{padding:10px 20px;border-radius:7px;font-family:'Space Mono',monospace;font-size:0.79rem;font-weight:700;cursor:pointer;border:none;transition:all 0.15s}\n.btn-primary{background:var(--accent);color:#0d0d0f}\n.btn-primary:hover{background:#ffd84a;transform:translateY(-1px)}\n.btn-secondary{background:transparent;border:1px solid var(--border);color:var(--muted)}\n.btn-secondary:hover{border-color:var(--text);color:var(--text)}\n.btn:disabled{opacity:0.4;cursor:default;transform:none!important}\n.loading{display:flex;align-items:center;gap:10px;color:var(--muted);font-size:0.81rem;padding:32px 0;justify-content:center}\n.spinner{width:16px;height:16px;border:2px solid var(--border);border-top-color:var(--accent);border-radius:50%;animation:spin 0.6s linear infinite;flex-shrink:0}\n@keyframes spin{to{transform:rotate(360deg)}}\n.error-box{padding:16px;border-radius:8px;background:rgba(240,96,96,0.08);border:1px solid var(--accent3);color:#f09090;font-size:0.81rem;line-height:1.6;margin-bottom:14px}\n.welcome{text-align:center;padding:36px 16px}\n.welcome h2{font-family:'Syne',sans-serif;font-size:1.25rem;font-weight:800;margin-bottom:10px}\n.welcome p{color:var(--muted);font-size:0.79rem;line-height:1.75;margin-bottom:22px}\n.score-anim{position:fixed;top:60px;right:24px;font-family:'Syne',sans-serif;font-weight:800;font-size:1.4rem;color:var(--accent2);pointer-events:none;animation:scoreUp 1.2s ease forwards}\n@keyframes scoreUp{0%{opacity:1;transform:translateY(0)}100%{opacity:0;transform:translateY(-40px)}}\n</style>\n</head>\n<body>\n<div class=\"wrap\">\n<header>\n  <div class=\"logo\">EN<span>.</span>COACH</div>\n  <div class=\"stats\">\n    <div>Score <span class=\"stat-val\" id=\"stat-score\">0</span></div>\n    <div>Série <span class=\"stat-val\" id=\"stat-streak\">0</span>🔥</div>\n    <div>Exos <span class=\"stat-val\" id=\"stat-total\">0</span></div>\n  </div>\n</header>\n<div class=\"progress-bar\"><div class=\"progress-fill\" id=\"progress\"></div></div>\n<div class=\"topics\">\n  <button class=\"topic-btn active\" data-topic=\"everyday\">Quotidien</button>\n  <button class=\"topic-btn\" data-topic=\"tech\">Tech / n8n</button>\n  <button class=\"topic-btn\" data-topic=\"freelance\">Freelance</button>\n  <button class=\"topic-btn\" data-topic=\"travel\">Voyages</button>\n  <button class=\"topic-btn\" data-topic=\"numbers\">Chiffres</button>\n</div>\n<div class=\"level-row\">\n  <span class=\"level-label\">Niveau :</span>\n  <button class=\"level-btn active\" data-level=\"A1\">A1</button>\n  <button class=\"level-btn\" data-level=\"A2\">A2</button>\n  <button class=\"level-btn\" data-level=\"B1\">B1</button>\n</div>\n<div class=\"voice-bar\">\n  <span style=\"font-size:1rem\">🔊</span>\n  <label>Lecture auto</label>\n  <button class=\"voice-btn tts\" id=\"tts-toggle\" onclick=\"toggleTTS()\">OFF</button>\n  <span style=\"margin-left:auto;font-size:1rem\">🎤</span>\n  <label>Réponse vocale</label>\n  <button class=\"voice-btn stt\" id=\"stt-btn\" onclick=\"toggleSTT()\">Micro</button>\n</div>\n<div class=\"session-badge\"><div class=\"dot\"></div>Session active — Mistral AI</div>\n<div id=\"main-area\">\n  <div class=\"card\">\n    <div class=\"welcome\">\n      <h2>Bienvenue, JP 👋</h2>\n      <p>Exercices générés par Mistral AI, adaptés à ton niveau en temps réel.<br>Active la lecture vocale pour entendre les exercices. Utilise le micro pour répondre à l'oral.</p>\n      <button class=\"btn btn-primary\" onclick=\"loadExercise()\">Commencer →</button>\n    </div>\n  </div>\n</div>\n</div>\n<script>\nconst API_URL = window.location.origin + '/webhook/english-coach/ask';\nconst TOPICS = {everyday:'everyday life, greetings, food, weather, daily routines',tech:'computers, automation, n8n workflows, API, webhooks, deployment',freelance:'freelancing, client emails, invoices, proposals, business English',travel:'travel, hotels, transport, directions, ordering food',numbers:'numbers, dates, prices, quantities, telling the time'};\nlet currentTopic='everyday', currentLevel='A1';\nlet score=0, streak=0, totalDone=0, sessionPts=0;\nlet answered=false, currentEx=null;\nlet ttsEnabled=false, recognition=null, isRecording=false;\nlet history=[];\n\ndocument.querySelectorAll('.topic-btn').forEach(b=>b.addEventListener('click',()=>{document.querySelectorAll('.topic-btn').forEach(x=>x.classList.remove('active'));b.classList.add('active');currentTopic=b.dataset.topic}));\ndocument.querySelectorAll('.level-btn').forEach(b=>b.addEventListener('click',()=>{document.querySelectorAll('.level-btn').forEach(x=>x.classList.remove('active'));b.classList.add('active');currentLevel=b.dataset.level}));\n\nfunction updateStats(){document.getElementById('stat-score').textContent=score;document.getElementById('stat-streak').textContent=streak;document.getElementById('stat-total').textContent=totalDone;document.getElementById('progress').style.width=(sessionPts%100)+'%'}\n\nfunction toggleTTS(){ttsEnabled=!ttsEnabled;const btn=document.getElementById('tts-toggle');btn.textContent=ttsEnabled?'ON':'OFF';btn.classList.toggle('on',ttsEnabled)}\n\nfunction speak(text){if(!ttsEnabled||!text)return;window.speechSynthesis.cancel();const u=new SpeechSynthesisUtterance(text);u.lang='en-GB';u.rate=0.88;u.pitch=1;const voices=window.speechSynthesis.getVoices();const pref=voices.find(v=>v.lang.startsWith('en')&&v.name.toLowerCase().includes('female'))||voices.find(v=>v.lang.startsWith('en'));if(pref)u.voice=pref;window.speechSynthesis.speak(u)}\n\nfunction toggleSTT(){if(!('webkitSpeechRecognition' in window||'SpeechRecognition' in window)){alert('Reconnaissance vocale non supportée sur ce navigateur. Utilise Chrome.');return}\nif(isRecording){recognition&&recognition.stop();return}\nconst SR=window.SpeechRecognition||window.webkitSpeechRecognition;recognition=new SR();recognition.lang='en-US';recognition.interimResults=false;recognition.maxAlternatives=1;\nrecognition.onstart=()=>{isRecording=true;document.getElementById('stt-btn').classList.add('recording');document.getElementById('stt-btn').textContent='...'}\nrecognition.onresult=(e)=>{const transcript=e.results[0][0].transcript;fillVoiceAnswer(transcript)}\nrecognition.onerror=()=>{isRecording=false;document.getElementById('stt-btn').classList.remove('recording');document.getElementById('stt-btn').textContent='Micro'}\nrecognition.onend=()=>{isRecording=false;document.getElementById('stt-btn').classList.remove('recording');document.getElementById('stt-btn').textContent='Micro'}\nrecognition.start()}\n\nfunction fillVoiceAnswer(text){if(!currentEx||answered)return;\nif(currentEx.type==='fill_blank'){const inp=document.getElementById('fill-in');if(inp){inp.value=text;checkFill()}}\nelse if(currentEx.type==='translation_fr_to_en'){const inp=document.getElementById('transl-in');if(inp){inp.value=text;checkTransl()}}}\n\nasync function loadExercise(){answered=false;currentEx=null;\nconst area=document.getElementById('main-area');\narea.innerHTML='<div class=\"card\"><div class=\"loading\"><div class=\"spinner\"></div>Mistral génère votre exercice...</div></div>';\ntry{\nconst res=await fetch(API_URL,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({topic:currentTopic,topic_desc:TOPICS[currentTopic],level:currentLevel,history:history.slice(-6)})});\nif(!res.ok)throw new Error('HTTP '+res.status);\nconst ex=await res.json();\ncurrentEx=ex;\nhistory.push({topic:currentTopic,level:currentLevel,type:ex.type,correct:null});\nrenderExercise(ex);\nif(ttsEnabled){\nsetTimeout(()=>{\nconst q=ex.question_en||(ex.type==='translation_fr_to_en'?'Translate: '+ex.french_text:'');\nspeak(q);\n},400)}\n}catch(e){\narea.innerHTML='<div class=\"card\"><div class=\"error-box\">⚠️ Erreur : '+e.message+'<br><small>Vérifie que le workflow n8n \"English Coach - Mistral Agent\" est actif.</small></div><div class=\"btn-row\"><button class=\"btn btn-primary\" onclick=\"loadExercise()\">Réessayer</button></div></div>';\n}}\n\nfunction renderExercise(ex){\nconst area=document.getElementById('main-area');\nconst labels={multiple_choice:'QCM',fill_blank:'Compléter',translation_fr_to_en:'Traduction'};\nlet inner='';\nif(ex.type==='multiple_choice'){\ninner='<div class=\"question\">'+ex.question_en+'<span class=\"fr-hint\">'+ex.question_fr_hint+'</span></div><div class=\"options\">'+(ex.options||[]).map((o,i)=>'<div class=\"opt\" id=\"opt-'+i+'\" onclick=\"checkMC('+i+','+ex.correct_index+')\"><div class=\"opt-letter\">'+String.fromCharCode(65+i)+'</div><span>'+o+'</span></div>').join('')+'</div>';\n}else if(ex.type==='fill_blank'){\ninner='<div class=\"question\">Complète la phrase :<span class=\"fr-hint\">'+ex.question_fr_hint+'</span></div><div class=\"fill-wrap\"><span class=\"sentence-part\">'+(ex.sentence_before||'')+'</span><input class=\"fill-input\" id=\"fill-in\" placeholder=\"???\" autocomplete=\"off\" autocorrect=\"off\" spellcheck=\"false\" onkeydown=\"if(event.key===\\'Enter\\')checkFill()\"><span class=\"sentence-part\">'+(ex.sentence_after||'')+'</span></div><div class=\"hint-box\">💡 '+ex.hint_fr+'</div><div class=\"btn-row\"><button class=\"btn btn-primary\" id=\"fill-btn\" onclick=\"checkFill()\">Valider</button><button class=\"voice-btn stt\" onclick=\"toggleSTT()\" style=\"padding:8px 14px\">🎤</button></div>';\n}else{\ninner='<div class=\"question\">Traduis en anglais :<span class=\"fr-hint\">'+ex.question_fr_hint+'</span></div><div class=\"fr-source\">'+ex.french_text+'</div><textarea class=\"transl-input\" id=\"transl-in\" rows=\"2\" placeholder=\"Type or say your answer in English...\" spellcheck=\"false\"></textarea><div class=\"btn-row\"><button class=\"btn btn-primary\" id=\"transl-btn\" onclick=\"checkTransl()\">Valider</button><button class=\"voice-btn stt\" onclick=\"toggleSTT()\" style=\"padding:8px 14px\">🎤</button></div>';\n}\narea.innerHTML='<div class=\"card\"><div class=\"exercise-meta\"><span class=\"ex-type\">'+(labels[ex.type]||ex.type)+'</span><span class=\"ex-level\">'+currentLevel+' · '+TOPICS[currentTopic].split(',')[0]+'</span>'+(ex.adapted?'<span style=\"font-size:0.6rem;color:var(--accent2);margin-left:4px\">↗ adapté</span>':'')+'</div>'+inner+'<div class=\"feedback\" id=\"fb\"></div><div class=\"btn-row\" id=\"next-row\" style=\"display:none\"><button class=\"btn btn-primary\" onclick=\"loadExercise()\">Exercice suivant →</button><button class=\"btn btn-secondary\" onclick=\"window.scrollTo(0,0)\">Changer</button></div></div>';\nif(ex.type==='fill_blank')setTimeout(()=>document.getElementById('fill-in')?.focus(),80);\nif(ex.type==='translation_fr_to_en')setTimeout(()=>document.getElementById('transl-in')?.focus(),80);\n}\n\nfunction showFeedback(correct,wrongHint){\nconst ex=currentEx;\nconst fb=document.getElementById('fb');\nconst next=document.getElementById('next-row');\nif(!fb)return;\nfb.className='feedback show '+(correct?'correct-fb':'wrong-fb');\nfb.innerHTML=correct?'✅ <strong>Correct !</strong> '+ex.explanation_fr:'❌ <strong>Pas tout à fait.</strong>'+(wrongHint?' Bonne réponse : <strong>'+wrongHint+'</strong><br>':'')+' '+ex.explanation_fr;\nif(next)next.style.display='flex';\nanswered=true;totalDone++;\nif(correct){score+=10;streak++;sessionPts+=10;showScoreAnim();}else{streak=0;}\nif(history.length)history[history.length-1].correct=correct;\nif(ttsEnabled){\nconst msg=correct?'Correct! '+ex.explanation_en:'Not quite. The answer is: '+(wrongHint||'');\nsetTimeout(()=>speak(msg),200);\n}\nupdateStats();\n}\n\nfunction showScoreAnim(){const el=document.createElement('div');el.className='score-anim';el.textContent='+10';document.body.appendChild(el);setTimeout(()=>el.remove(),1200)}\n\nfunction checkMC(chosen,correct){if(answered)return;document.querySelectorAll('.opt').forEach(o=>o.classList.add('disabled'));document.getElementById('opt-'+chosen)?.classList.add(chosen===correct?'correct':'wrong');if(chosen!==correct)document.getElementById('opt-'+correct)?.classList.add('correct');showFeedback(chosen===correct,chosen!==correct?(currentEx?.options?.[correct]):null)}\n\nfunction checkFill(){if(answered)return;const inp=document.getElementById('fill-in');const btn=document.getElementById('fill-btn');if(!inp||!currentEx)return;const val=inp.value.trim().toLowerCase();const exp=(currentEx.answer||'').trim().toLowerCase();const ok=val===exp||val.replace(/[^a-z]/g,'')===exp.replace(/[^a-z]/g,'');inp.classList.add(ok?'correct':'wrong');inp.disabled=true;if(btn)btn.disabled=true;showFeedback(ok,ok?null:currentEx.answer)}\n\nfunction checkTransl(){if(answered)return;const inp=document.getElementById('transl-in');const btn=document.getElementById('transl-btn');if(!inp||!currentEx)return;const norm=s=>s.toLowerCase().replace(/[^a-z0-9\\s]/g,'').trim().replace(/\\s+/g,' ');const val=norm(inp.value);const all=[currentEx.answer_en,...(currentEx.accepted_variants||[])].map(norm);const ok=all.some(a=>val===a||(val.length>3&&(a.includes(val)||val.includes(a))));inp.classList.add(ok?'correct':'wrong');inp.disabled=true;if(btn)btn.disabled=true;showFeedback(ok,ok?null:currentEx.answer_en)}\n\nwindow.speechSynthesis&&window.speechSynthesis.getVoices();\nupdateStats();\n</script>\n</body>\n</html>",
