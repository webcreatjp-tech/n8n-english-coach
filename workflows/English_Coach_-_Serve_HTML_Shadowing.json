    {
      "parameters": {
        "respondWith": "text",
        "responseBody": "<!DOCTYPE html>\n<html lang=\"fr\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>EN.SPEAK</title>\n<link href=\"https://fonts.googleapis.com/css2?family=Archivo+Black&family=DM+Mono:ital,wght@0,400;0,500;1,400&display=swap\" rel=\"stylesheet\">\n<style>\n:root{\n  --bg:#080a0e;--surface:#0f1117;--surface2:#171b24;--border:#1e2433;\n  --accent:#00e5ff;--accent2:#ff6b35;--accent3:#39ff8f;--accent4:#ffd60a;\n  --text:#dde4f0;--muted:#4a5568;--radius:14px;\n}\n*{box-sizing:border-box;margin:0;padding:0}\nbody{\n  background:var(--bg);color:var(--text);\n  font-family:'DM Mono',monospace;\n  min-height:100vh;display:flex;flex-direction:column;align-items:center;\n  padding:0 0 80px;overflow-x:hidden;\n}\n\n/* Scan line background effect */\nbody::after{\n  content:'';position:fixed;inset:0;\n  background:repeating-linear-gradient(0deg,transparent,transparent 2px,rgba(0,229,255,0.012) 2px,rgba(0,229,255,0.012) 4px);\n  pointer-events:none;z-index:0;\n}\n\n.wrap{position:relative;z-index:1;width:100%;max-width:600px;padding:0 16px}\n\n/* Header */\nheader{\n  padding:28px 0 24px;\n  display:flex;align-items:center;justify-content:space-between;\n}\n.logo{\n  font-family:'Archivo Black',sans-serif;\n  font-size:1.4rem;letter-spacing:-0.03em;\n  color:var(--text);\n}\n.logo em{color:var(--accent);font-style:normal}\n.session-info{font-size:0.65rem;color:var(--muted);text-align:right;line-height:1.6}\n.session-info span{color:var(--accent3);font-weight:500}\n\n/* Stats bar */\n.stats{\n  display:grid;grid-template-columns:repeat(3,1fr);gap:8px;\n  margin-bottom:20px;\n}\n.stat-box{\n  background:var(--surface);border:1px solid var(--border);\n  border-radius:10px;padding:12px 14px;\n  display:flex;flex-direction:column;gap:3px;\n}\n.stat-box .val{\n  font-family:'Archivo Black',sans-serif;\n  font-size:1.4rem;color:var(--accent);line-height:1;\n}\n.stat-box .lbl{font-size:0.6rem;color:var(--muted);text-transform:uppercase;letter-spacing:0.06em}\n\n/* Topic selector */\n.topics{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:12px}\n.topic-btn{\n  padding:5px 12px;background:var(--surface);\n  border:1px solid var(--border);border-radius:20px;\n  color:var(--muted);font-family:'DM Mono',monospace;font-size:0.67rem;\n  cursor:pointer;transition:all 0.15s;\n}\n.topic-btn:hover{border-color:var(--accent);color:var(--accent)}\n.topic-btn.active{background:rgba(0,229,255,0.1);border-color:var(--accent);color:var(--accent);font-weight:500}\n\n/* Level */\n.level-row{display:flex;align-items:center;gap:6px;margin-bottom:20px}\n.level-lbl{font-size:0.62rem;color:var(--muted)}\n.level-btn{\n  padding:3px 10px;background:var(--surface);border:1px solid var(--border);\n  border-radius:10px;color:var(--muted);font-family:'DM Mono',monospace;\n  font-size:0.65rem;cursor:pointer;transition:all 0.15s;\n}\n.level-btn.active{background:rgba(57,255,143,0.1);border-color:var(--accent3);color:var(--accent3)}\n\n/* Main card */\n.card{\n  background:var(--surface);border:1px solid var(--border);\n  border-radius:var(--radius);overflow:hidden;margin-bottom:12px;\n  position:relative;\n}\n\n/* Glowing top border */\n.card::before{\n  content:'';position:absolute;top:0;left:0;right:0;height:1px;\n  background:linear-gradient(90deg,transparent,var(--accent),transparent);\n}\n\n.card-header{\n  padding:16px 20px 12px;\n  display:flex;align-items:center;justify-content:space-between;\n  border-bottom:1px solid var(--border);\n}\n.card-tag{\n  font-size:0.58rem;font-weight:500;letter-spacing:0.1em;\n  text-transform:uppercase;padding:3px 9px;border-radius:4px;\n}\n.tag-shadow{background:rgba(0,229,255,0.1);color:var(--accent);border:1px solid rgba(0,229,255,0.2)}\n.tag-qa{background:rgba(255,107,53,0.1);color:var(--accent2);border:1px solid rgba(255,107,53,0.2)}\n.card-step{font-size:0.62rem;color:var(--muted)}\n\n.card-body{padding:24px 20px}\n\n/* La phrase en anglais — grande et claire */\n.sentence-en{\n  font-family:'Archivo Black',sans-serif;\n  font-size:1.6rem;line-height:1.35;\n  color:var(--text);margin-bottom:10px;\n  letter-spacing:-0.02em;\n}\n.sentence-en.speaking{color:var(--accent);animation:glow 1.5s ease-in-out infinite}\n@keyframes glow{0%,100%{text-shadow:0 0 10px rgba(0,229,255,0.3)}50%{text-shadow:0 0 30px rgba(0,229,255,0.8)}}\n\n/* Traduction française */\n.sentence-fr{\n  font-size:0.85rem;color:var(--muted);\n  margin-bottom:18px;font-style:italic;\n  padding:10px 14px;background:var(--surface2);\n  border-radius:8px;border-left:2px solid var(--border);\n  line-height:1.5;\n}\n\n/* Tip prononciation */\n.phonetic-tip{\n  font-size:0.72rem;color:var(--accent4);\n  margin-bottom:20px;\n  display:flex;align-items:flex-start;gap:6px;\n}\n.phonetic-tip::before{content:'👄';font-size:0.9rem}\n\n/* Zone vocale centrale */\n.voice-zone{\n  display:flex;flex-direction:column;align-items:center;\n  gap:16px;padding:20px 0 8px;\n}\n\n/* Bouton micro principal */\n.mic-btn{\n  width:80px;height:80px;border-radius:50%;\n  border:2px solid var(--border);\n  background:var(--surface2);\n  cursor:pointer;transition:all 0.2s;\n  display:flex;align-items:center;justify-content:center;\n  font-size:2rem;position:relative;\n}\n.mic-btn::after{\n  content:'';position:absolute;inset:-6px;border-radius:50%;\n  border:1px solid transparent;transition:all 0.2s;\n}\n.mic-btn:hover{border-color:var(--accent3);background:rgba(57,255,143,0.05)}\n.mic-btn:hover::after{border-color:rgba(57,255,143,0.3)}\n.mic-btn.recording{\n  border-color:var(--accent2);\n  background:rgba(255,107,53,0.1);\n  animation:recpulse 1s ease infinite;\n}\n.mic-btn.recording::after{border-color:rgba(255,107,53,0.4);animation:ripple 1s ease infinite}\n@keyframes recpulse{0%,100%{transform:scale(1)}50%{transform:scale(1.06)}}\n@keyframes ripple{0%{inset:-6px;opacity:1}100%{inset:-20px;opacity:0}}\n\n/* Bouton rejouer TTS */\n.replay-btn{\n  display:flex;align-items:center;gap:6px;\n  padding:7px 16px;border-radius:20px;\n  background:transparent;border:1px solid var(--border);\n  color:var(--muted);font-family:'DM Mono',monospace;font-size:0.7rem;\n  cursor:pointer;transition:all 0.15s;\n}\n.replay-btn:hover{border-color:var(--accent);color:var(--accent)}\n\n.voice-status{\n  font-size:0.72rem;color:var(--muted);text-align:center;min-height:20px;\n  transition:color 0.2s;\n}\n.voice-status.active{color:var(--accent3)}\n.voice-status.recording{color:var(--accent2)}\n.voice-status.error{color:#ff4444}\n\n/* Résultat de la comparaison */\n.result-zone{\n  margin-top:16px;padding:16px;\n  background:var(--surface2);border-radius:10px;\n  border:1px solid var(--border);\n  display:none;\n}\n.result-zone.show{display:block;animation:fadeIn 0.25s ease}\n@keyframes fadeIn{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:translateY(0)}}\n\n.score-row{\n  display:flex;align-items:center;justify-content:space-between;\n  margin-bottom:12px;\n}\n.score-circle{\n  width:52px;height:52px;border-radius:50%;\n  display:flex;align-items:center;justify-content:center;\n  font-family:'Archivo Black',sans-serif;font-size:1rem;\n  border:2px solid;\n}\n.score-circle.great{border-color:var(--accent3);color:var(--accent3);background:rgba(57,255,143,0.08)}\n.score-circle.ok{border-color:var(--accent4);color:var(--accent4);background:rgba(255,214,10,0.08)}\n.score-circle.retry{border-color:var(--accent2);color:var(--accent2);background:rgba(255,107,53,0.08)}\n\n.what-you-said{font-size:0.78rem;color:var(--muted);font-style:italic;flex:1;margin-left:12px;line-height:1.4}\n.what-you-said strong{color:var(--text)}\n\n.result-feedback{font-size:0.78rem;color:var(--muted);line-height:1.6;margin-bottom:12px}\n.result-feedback.correct-fb{color:#90f0c8}\n.result-feedback.wrong-fb{color:#f0a090}\n\n/* Mots corrects/manqués */\n.word-check{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:14px}\n.word-tag{\n  padding:3px 8px;border-radius:4px;font-size:0.7rem;\n}\n.word-ok{background:rgba(57,255,143,0.1);color:var(--accent3);border:1px solid rgba(57,255,143,0.2)}\n.word-miss{background:rgba(255,107,53,0.1);color:var(--accent2);border:1px solid rgba(255,107,53,0.2)}\n\n.explication-box{\n  font-size:0.74rem;color:var(--muted);line-height:1.65;\n  padding:10px 12px;background:var(--bg);border-radius:7px;\n  border-left:2px solid var(--accent);\n}\n\n/* Boutons action */\n.action-row{display:flex;gap:10px;margin-top:16px;flex-wrap:wrap}\n.btn{\n  padding:11px 22px;border-radius:8px;\n  font-family:'DM Mono',monospace;font-size:0.77rem;font-weight:500;\n  cursor:pointer;border:none;transition:all 0.15s;\n}\n.btn-next{background:var(--accent);color:#080a0e;font-family:'Archivo Black',sans-serif;font-size:0.82rem}\n.btn-next:hover{background:#33eeff;transform:translateY(-1px)}\n.btn-retry{background:transparent;border:1px solid var(--border);color:var(--muted)}\n.btn-retry:hover{border-color:var(--accent2);color:var(--accent2)}\n.btn:disabled{opacity:0.35;cursor:default;transform:none!important}\n\n/* Loading */\n.loading{\n  display:flex;flex-direction:column;align-items:center;gap:14px;\n  padding:48px 20px;color:var(--muted);font-size:0.78rem;\n}\n.loader{\n  width:32px;height:32px;border:2px solid var(--border);\n  border-top-color:var(--accent);border-radius:50%;\n  animation:spin 0.7s linear infinite;\n}\n@keyframes spin{to{transform:rotate(360deg)}}\n\n/* Error */\n.error-card{\n  padding:18px 20px;border-radius:var(--radius);\n  background:rgba(255,107,53,0.06);border:1px solid rgba(255,107,53,0.2);\n  color:#f0a090;font-size:0.78rem;line-height:1.7;\n}\n\n/* Welcome */\n.welcome-card{padding:36px 24px;text-align:center}\n.welcome-card h2{\n  font-family:'Archivo Black',sans-serif;\n  font-size:1.4rem;margin-bottom:10px;letter-spacing:-0.02em;\n}\n.welcome-card p{color:var(--muted);font-size:0.77rem;line-height:1.8;margin-bottom:24px}\n.start-btn{\n  display:inline-flex;align-items:center;gap:8px;\n  padding:14px 28px;background:var(--accent);color:#080a0e;\n  border-radius:10px;border:none;cursor:pointer;\n  font-family:'Archivo Black',sans-serif;font-size:0.95rem;\n  transition:all 0.15s;\n}\n.start-btn:hover{background:#33eeff;transform:translateY(-2px)}\n\n/* Chrome warning */\n.chrome-warn{\n  font-size:0.68rem;color:var(--muted);text-align:center;\n  padding:8px 14px;background:rgba(255,214,10,0.05);\n  border:1px solid rgba(255,214,10,0.15);border-radius:8px;\n  margin-bottom:14px;display:none;\n}\n</style>\n</head>\n<body>\n<div class=\"wrap\">\n\n<header>\n  <div class=\"logo\">EN<em>.</em>SPEAK</div>\n  <div class=\"session-info\">\n    Mistral AI · Shadowing<br>\n    Chrome recommandé\n  </div>\n</header>\n\n<div class=\"stats\">\n  <div class=\"stat-box\"><div class=\"val\" id=\"stat-score\">0</div><div class=\"lbl\">Score</div></div>\n  <div class=\"stat-box\"><div class=\"val\" id=\"stat-streak\">0</div><div class=\"lbl\">Série 🔥</div></div>\n  <div class=\"stat-box\"><div class=\"val\" id=\"stat-total\">0</div><div class=\"lbl\">Phrases</div></div>\n</div>\n\n<div id=\"chrome-warn\" class=\"chrome-warn\">⚠️ Le micro nécessite Chrome ou Edge — Firefox non supporté pour la reconnaissance vocale.</div>\n\n<div class=\"topics\">\n  <button class=\"topic-btn active\" data-topic=\"everyday\" data-desc=\"everyday life, greetings, food, weather, daily routines\">Quotidien</button>\n  <button class=\"topic-btn\" data-topic=\"tech\" data-desc=\"computers, automation, n8n, software, tech support\">Tech / n8n</button>\n  <button class=\"topic-btn\" data-topic=\"freelance\" data-desc=\"freelancing, client communication, emails, business\">Freelance</button>\n  <button class=\"topic-btn\" data-topic=\"travel\" data-desc=\"travel, hotels, transport, directions, restaurants\">Voyages</button>\n</div>\n<div class=\"level-row\">\n  <span class=\"level-lbl\">Niveau :</span>\n  <button class=\"level-btn active\" data-level=\"A1\">A1</button>\n  <button class=\"level-btn\" data-level=\"A2\">A2</button>\n  <button class=\"level-btn\" data-level=\"B1\">B1</button>\n</div>\n\n<div id=\"main-area\">\n  <div class=\"card\">\n    <div class=\"welcome-card\">\n      <h2>Bonjour JP 👋</h2>\n      <p>\n        Mode <strong style=\"color:var(--accent)\">shadowing</strong> — pratique l'anglais à l'oral.<br>\n        La phrase s'affiche et se lit automatiquement.<br>\n        Tu répètes, le micro compare, tu progresses.\n      </p>\n      <button class=\"start-btn\" onclick=\"loadExercise()\">🎙️ Commencer</button>\n    </div>\n  </div>\n</div>\n\n</div>\n<script>\nconst API_URL = window.location.origin + '/webhook/english-coach/ask';\nconst TOPICS = {};\ndocument.querySelectorAll('.topic-btn').forEach(b => {\n  TOPICS[b.dataset.topic] = b.dataset.desc;\n  b.addEventListener('click', () => {\n    document.querySelectorAll('.topic-btn').forEach(x => x.classList.remove('active'));\n    b.classList.add('active');\n    currentTopic = b.dataset.topic;\n  });\n});\ndocument.querySelectorAll('.level-btn').forEach(b => {\n  b.addEventListener('click', () => {\n    document.querySelectorAll('.level-btn').forEach(x => x.classList.remove('active'));\n    b.classList.add('active');\n    currentLevel = b.dataset.level;\n  });\n});\n\nlet currentTopic = 'everyday';\nlet currentLevel = 'A1';\nlet score = 0, streak = 0, totalDone = 0, sessionCount = 0;\nlet history = [];\nlet currentEx = null;\nlet recognition = null;\nlet isRecording = false;\nlet ttsReady = false;\n\n// Détecter si pas Chrome\nconst isChrome = /Chrome/.test(navigator.userAgent) && /Google Inc/.test(navigator.vendor);\nif (!isChrome) document.getElementById('chrome-warn').style.display = 'block';\n\nfunction updateStats() {\n  document.getElementById('stat-score').textContent = score;\n  document.getElementById('stat-streak').textContent = streak;\n  document.getElementById('stat-total').textContent = totalDone;\n}\n\n// TTS — lit la phrase en anglais\nfunction speak(text, onEnd) {\n  if (!text) { if (onEnd) onEnd(); return; }\n  window.speechSynthesis.cancel();\n  const u = new SpeechSynthesisUtterance(text);\n  u.lang = 'en-GB';\n  u.rate = 0.82;\n  u.pitch = 1.05;\n  const voices = window.speechSynthesis.getVoices();\n  const voice = voices.find(v => v.lang.startsWith('en-GB') && v.name.includes('Female'))\n    || voices.find(v => v.lang.startsWith('en-GB'))\n    || voices.find(v => v.lang.startsWith('en'));\n  if (voice) u.voice = voice;\n  u.onend = () => { if (onEnd) onEnd(); };\n  u.onerror = () => { if (onEnd) onEnd(); };\n  document.querySelector('.sentence-en')?.classList.add('speaking');\n  u.onend = () => {\n    document.querySelector('.sentence-en')?.classList.remove('speaking');\n    if (onEnd) onEnd();\n  };\n  window.speechSynthesis.speak(u);\n}\n\nfunction speakFR(text) {\n  if (!text) return;\n  window.speechSynthesis.cancel();\n  const u = new SpeechSynthesisUtterance(text);\n  u.lang = 'fr-FR'; u.rate = 0.9;\n  window.speechSynthesis.speak(u);\n}\n\n// Charger exercice\nasync function loadExercise() {\n  currentEx = null;\n  window.speechSynthesis.cancel();\n  const area = document.getElementById('main-area');\n  area.innerHTML = '<div class=\"card\"><div class=\"loading\"><div class=\"loader\"></div>Mistral génère une phrase...</div></div>';\n\n  try {\n    const res = await fetch(API_URL, {\n      method: 'POST',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({\n        topic: currentTopic,\n        topic_desc: TOPICS[currentTopic],\n        level: currentLevel,\n        history: history.slice(-6),\n        sessionCount: sessionCount++\n      })\n    });\n    if (!res.ok) throw new Error('HTTP ' + res.status);\n    const ex = await res.json();\n    currentEx = ex;\n    history.push({ type: ex.type, correct: null });\n    renderExercise(ex);\n    // Lecture automatique après un court délai\n    setTimeout(() => {\n      setStatus('Écoute...', 'active');\n      speak(ex.sentence_en, () => {\n        setStatus('Micro prêt — clique sur 🎤 pour répéter', '');\n      });\n    }, 600);\n  } catch(e) {\n    area.innerHTML = `<div class=\"card\"><div class=\"error-card\">⚠️ Erreur : ${e.message}<br><small style=\"opacity:0.6\">Vérifie que le workflow n8n Shadowing Agent est actif.</small></div><div style=\"padding:0 20px 20px\"><button class=\"btn btn-next\" onclick=\"loadExercise()\" style=\"margin-top:12px\">Réessayer</button></div></div>`;\n  }\n}\n\nfunction setStatus(msg, cls) {\n  const el = document.getElementById('voice-status');\n  if (!el) return;\n  el.textContent = msg;\n  el.className = 'voice-status' + (cls ? ' ' + cls : '');\n}\n\nfunction renderExercise(ex) {\n  const area = document.getElementById('main-area');\n  const tagClass = ex.type === 'shadowing' ? 'tag-shadow' : 'tag-qa';\n  const tagLabel = ex.type === 'shadowing' ? '🔁 Shadowing' : '💬 Q&A';\n\n  let qaHint = '';\n  if (ex.type === 'qa' && ex.suggested_answer_en) {\n    qaHint = `<div style=\"margin-top:10px;padding:10px 14px;background:var(--surface2);border-radius:8px;border-left:2px solid var(--accent2);\">\n      <div style=\"font-size:0.62rem;color:var(--accent2);text-transform:uppercase;letter-spacing:0.08em;margin-bottom:4px\">Réponse suggérée</div>\n      <div style=\"font-family:'Archivo Black',sans-serif;font-size:1.1rem\">${ex.suggested_answer_en}</div>\n      <div style=\"font-size:0.78rem;color:var(--muted);font-style:italic;margin-top:3px\">${ex.suggested_answer_fr || ''}</div>\n    </div>`;\n  }\n\n  area.innerHTML = `\n  <div class=\"card\" id=\"ex-card\">\n    <div class=\"card-header\">\n      <span class=\"card-tag ${tagClass}\">${tagLabel}</span>\n      <span class=\"card-step\">${currentLevel} · ${TOPICS[currentTopic].split(',')[0]}</span>\n    </div>\n    <div class=\"card-body\">\n      <div class=\"sentence-en\" id=\"sent-en\">${ex.sentence_en}</div>\n      <div class=\"sentence-fr\">${ex.sentence_fr}</div>\n      ${ex.phonetic_tip ? `<div class=\"phonetic-tip\">${ex.phonetic_tip}</div>` : ''}\n      ${qaHint}\n      <div class=\"voice-zone\">\n        <button class=\"replay-btn\" onclick=\"replaySpeech()\">▶ Réécouter</button>\n        <button class=\"mic-btn\" id=\"mic-btn\" onclick=\"toggleMic()\">🎤</button>\n        <div class=\"voice-status\" id=\"voice-status\">Écoute la phrase, puis répète</div>\n      </div>\n      <div class=\"result-zone\" id=\"result-zone\"></div>\n    </div>\n  </div>`;\n}\n\nfunction replaySpeech() {\n  if (!currentEx) return;\n  window.speechSynthesis.cancel();\n  setStatus('Écoute...', 'active');\n  speak(currentEx.sentence_en, () => setStatus('Prêt — clique sur 🎤', ''));\n}\n\nfunction toggleMic() {\n  if (isRecording) {\n    recognition && recognition.stop();\n    return;\n  }\n  if (!('webkitSpeechRecognition' in window || 'SpeechRecognition' in window)) {\n    setStatus('Micro non supporté — utilise Chrome', 'error');\n    return;\n  }\n  window.speechSynthesis.cancel();\n  const SR = window.SpeechRecognition || window.webkitSpeechRecognition;\n  recognition = new SR();\n  recognition.lang = 'en-US';\n  recognition.interimResults = false;\n  recognition.maxAlternatives = 3;\n\n  recognition.onstart = () => {\n    isRecording = true;\n    document.getElementById('mic-btn')?.classList.add('recording');\n    setStatus('Je t\\'écoute...', 'recording');\n  };\n  recognition.onresult = (e) => {\n    const transcript = e.results[0][0].transcript;\n    processResult(transcript);\n  };\n  recognition.onerror = (e) => {\n    isRecording = false;\n    document.getElementById('mic-btn')?.classList.remove('recording');\n    if (e.error === 'no-speech') setStatus('Aucun son détecté — réessaie', 'error');\n    else setStatus('Erreur micro : ' + e.error, 'error');\n  };\n  recognition.onend = () => {\n    isRecording = false;\n    document.getElementById('mic-btn')?.classList.remove('recording');\n  };\n  recognition.start();\n}\n\nfunction processResult(transcript) {\n  if (!currentEx) return;\n  setStatus('Analyse...', '');\n\n  const normalize = s => s.toLowerCase().replace(/[^a-z\\s]/g, '').trim().replace(/\\s+/g, ' ');\n  const said = normalize(transcript);\n  const expected = normalize(currentEx.sentence_en);\n  const expectedWords = (currentEx.expected_words || expected.split(' ')).map(w => normalize(w));\n\n  // Calcul score de similarité mot par mot\n  const saidWords = said.split(' ');\n  let matched = 0;\n  const wordResults = expectedWords.map(w => {\n    const found = saidWords.some(sw => sw === w || sw.startsWith(w.substring(0, Math.max(3, w.length - 1))));\n    if (found) matched++;\n    return { word: w, ok: found };\n  });\n\n  const pct = Math.round((matched / Math.max(expectedWords.length, 1)) * 100);\n\n  // Mise à jour score\n  totalDone++;\n  const correct = pct >= 60;\n  if (correct) { score += pct >= 85 ? 10 : 5; streak++; }\n  else { streak = 0; }\n  if (history.length) history[history.length - 1].correct = correct;\n  updateStats();\n\n  // Afficher résultat\n  showResult(pct, wordResults, transcript, correct);\n}\n\nfunction showResult(pct, wordResults, transcript, correct) {\n  const ex = currentEx;\n  const zone = document.getElementById('result-zone');\n  if (!zone) return;\n\n  const circleClass = pct >= 85 ? 'great' : pct >= 60 ? 'ok' : 'retry';\n  const emoji = pct >= 85 ? '🎯' : pct >= 60 ? '👍' : '🔄';\n  const feedbackMsg = pct >= 85\n    ? 'Excellent ! Très bonne prononciation.'\n    : pct >= 60\n    ? 'Bien ! Encore un peu de pratique.'\n    : 'À réessayer — écoute bien la phrase.';\n  const fbClass = correct ? 'correct-fb' : 'wrong-fb';\n\n  const wordTags = wordResults.map(w =>\n    `<span class=\"word-tag ${w.ok ? 'word-ok' : 'word-miss'}\">${w.word}</span>`\n  ).join('');\n\n  zone.className = 'result-zone show';\n  zone.innerHTML = `\n    <div class=\"score-row\">\n      <div class=\"score-circle ${circleClass}\">${pct}%</div>\n      <div class=\"what-you-said\">Tu as dit :<br><strong>\"${transcript}\"</strong></div>\n    </div>\n    <div class=\"word-check\">${wordTags}</div>\n    <div class=\"result-feedback ${fbClass}\">${emoji} ${feedbackMsg}</div>\n    <div class=\"explication-box\">${ex.explanation_fr}</div>\n    <div class=\"action-row\">\n      <button class=\"btn btn-next\" onclick=\"loadExercise()\">Phrase suivante →</button>\n      <button class=\"btn btn-retry\" onclick=\"retryExercise()\">🔄 Réessayer</button>\n    </div>`;\n\n  setStatus('', '');\n\n  // Feedback vocal\n  const ttsMsg = correct\n    ? ex.explanation_en\n    : 'Not quite. Listen again and try to repeat: ' + ex.sentence_en;\n  setTimeout(() => speak(ttsMsg), 400);\n}\n\nfunction retryExercise() {\n  const zone = document.getElementById('result-zone');\n  if (zone) { zone.className = 'result-zone'; zone.innerHTML = ''; }\n  setStatus('Réécoute la phrase...', 'active');\n  speak(currentEx?.sentence_en, () => setStatus('Prêt — clique sur 🎤', ''));\n}\n\n// Init voix\nwindow.speechSynthesis && window.speechSynthesis.getVoices();\nwindow.speechSynthesis?.addEventListener('voiceschanged', () => {});\nupdateStats();\n</script>\n</body>\n</html>\n",
